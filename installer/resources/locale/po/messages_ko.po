#: ../i2prouter:226
msgid "Failed to load the wrapper"
msgstr "wrapper 불러오기에 실패했습니다"

#: ../i2prouter:998 ../i2prouter:1026 ../i2prouter:1100 ../i2prouter:1128
#: ../i2prouter:1149
#, sh-format
msgid "$APP_LONG_NAME is already running."
msgstr "$APP_LONG_NAME 은 이미 실행중입니다."

#: ../i2prouter:1009
#, sh-format
msgid "Running $APP_LONG_NAME"
msgstr "$APP_LONG_NAME 실행중"

#: ../i2prouter:1033
#, sh-format
msgid "Waiting for $APP_LONG_NAME"
msgstr "$APP_LONG_NAME 기다리는 중"

#: ../i2prouter:1080
#, sh-format
msgid "WARNING: $APP_LONG_NAME may have failed to start."
msgstr "경고: $APP_LONG_NAME 시작에 실패했을지도 모릅니다."

#: ../i2prouter:1094 ../i2prouter:1122 ../i2prouter:1328 ../i2prouter:1617
msgid "Must be root to perform this action."
msgstr "이 작업을 수행하기 위해선 루트가 필요합니다."

#: ../i2prouter:1138
#, sh-format
msgid "Starting $APP_LONG_NAME"
msgstr "$APP_LONG_NAME 시작중"

#: ../i2prouter:1160
#, sh-format
msgid "Stopping $APP_LONG_NAME"
msgstr "$APP_LONG_NAME 정지중"

#: ../i2prouter:1164 ../i2prouter:1232 ../i2prouter:1785
#, sh-format
msgid "$APP_LONG_NAME was not running."
msgstr "$APP_LONG_NAME 은 실행되고 있지 않았습니다."

#: ../i2prouter:1177 ../i2prouter:1185 ../i2prouter:1247 ../i2prouter:1255
#, sh-format
msgid "Unable to stop $APP_LONG_NAME."
msgstr "$APP_LONG_NAME 을 멈출 수 없습니다."

#: ../i2prouter:1203
#, sh-format
msgid "Waiting for $APP_LONG_NAME to exit"
msgstr "$APP_LONG_NAME 이 종료되기까지 기다리는 중"

#: ../i2prouter:1217
#, sh-format
msgid "Failed to stop $APP_LONG_NAME."
msgstr "$APP_LONG_NAME 정지에 실패했습니다."

#: ../i2prouter:1220
#, sh-format
msgid "Stopped $APP_LONG_NAME."
msgstr "$APP_LONG_NAME 정지됨."

#: ../i2prouter:1228
#, sh-format
msgid "Stopping $APP_LONG_NAME gracefully"
msgstr "우아하게 $APP_LONG_NAME 정지하는 중"

#: ../i2prouter:1274
#, sh-format
msgid "$APP_LONG_NAME is not running."
msgstr "$APP_LONG_NAME 은 실행중이 아닙니다."

#: ../i2prouter:1279
#, sh-format
msgid "$APP_LONG_NAME is running: PID:$pid"
msgstr "$APP_LONG_NAME 은 실행중입니다: PID:$pid"

#: ../i2prouter:1282
#, sh-format
msgid "$APP_LONG_NAME is running: PID:$pid, Wrapper:$STATUS, Java:$JAVASTATUS"
msgstr ""
"$APP_LONG_NAME 은 실행중입니다: PID:$pid, Wrapper:$STATUS,Java:$JAVASTATUS"

#: ../i2prouter:1335 ../i2prouter:1347 ../i2prouter:1366 ../i2prouter:1383
#: ../i2prouter:1450 ../i2prouter:1470 ../i2prouter:1484 ../i2prouter:1498
#: ../i2prouter:1526 ../i2prouter:1564 ../i2prouter:1599
#, sh-format
msgid "The $APP_LONG_NAME daemon is already installed."
msgstr "$APP_LONG_NAME 데몬은 이미 설치되어 있습니다."

#: ../i2prouter:1338 ../i2prouter:1353 ../i2prouter:1455 ../i2prouter:1487
#: ../i2prouter:1501 ../i2prouter:1515 ../i2prouter:1529 ../i2prouter:1567
#: ../i2prouter:1602
#, sh-format
msgid "Installing the $APP_LONG_NAME daemon"
msgstr "$APP_LONG_NAME 데몬 설치 중"

#: ../i2prouter:1609
#, sh-format
msgid "Install not currently supported for $DIST_OS"
msgstr "설치는 현재 $DIST_OS 에서 지원되지 않습니다"

#: ../i2prouter:1625 ../i2prouter:1638 ../i2prouter:1652 ../i2prouter:1661
#: ../i2prouter:1671 ../i2prouter:1695 ../i2prouter:1708 ../i2prouter:1720
#: ../i2prouter:1738 ../i2prouter:1751 ../i2prouter:1765
#, sh-format
msgid "Removing $APP_LONG_NAME daemon"
msgstr "$APP_LONG_NAME 데몬 제거중"

#: ../i2prouter:1631 ../i2prouter:1646 ../i2prouter:1655 ../i2prouter:1665
#: ../i2prouter:1676 ../i2prouter:1689 ../i2prouter:1701 ../i2prouter:1714
#: ../i2prouter:1732 ../i2prouter:1745 ../i2prouter:1759 ../i2prouter:1770
#, sh-format
msgid "The $APP_LONG_NAME daemon is not currently installed."
msgstr "$APP_LONG_NAME 데몬은 현재 설치되어 있지 않습니다."

#: ../i2prouter:1774
#, sh-format
msgid "Remove not currently supported for $DIST_OS"
msgstr "제거는 현재 $DIST_OS 에서 지원되지 않습니다"

#: ../i2prouter:1861
msgid "Commands:"
msgstr "명령어:"

#: ../i2prouter:1862
msgid "Launch in the current console."
msgstr "현재 콘솔에서 실행."

#: ../i2prouter:1863
msgid "Start in the background as a daemon process."
msgstr "데몬 프로세스로 백그라운드에서 시작."

#: ../i2prouter:1864
msgid "Stop if running as a daemon or in another console."
msgstr "다른 콘솔이나 데몬으로 실행중일 경우 정지."

#: ../i2prouter:1865
msgid "Stop gracefully, may take up to 11 minutes."
msgstr "우아하게 종료, 11분 이상 걸릴 수 있음."

#: ../i2prouter:1866
msgid "Stop if running and then start."
msgstr "실행중이면 정지하고 시작."

#: ../i2prouter:1867
msgid "Restart only if already running."
msgstr "현재 실행중일때만 재시작."

#: ../i2prouter:1868
msgid "Query the current status."
msgstr "현재 상태를 쿼리함."

#: ../i2prouter:1869
msgid "Install to start automatically when system boots."
msgstr "시스템 부트시에 자동으로 실행함."

#: ../i2prouter:1870
msgid "Uninstall."
msgstr "제거."

#: ../i2prouter:1871
msgid "Request a Java thread dump if running."
msgstr "실행중일 경우 Java 쓰레드 덤프를 요청함."

#: ../i2prouter:1884
msgid "Please edit i2prouter and set the variable RUN_AS_USER"
msgstr "i2prouter를 편집하여 RUN_AS_USER 변수를 설정하세요"

#: ../i2prouter:1889
msgid "Running I2P as the root user is *not* recommended."
msgstr "I2P를 루트 유저로 실행하는 것은 *비권장* 됩니다."

#: ../i2prouter:1892
msgid "To run as root anyway, edit i2prouter and set ALLOW_ROOT=true."
msgstr ""
"그래도 루트로 실행하고자 하면, i2prouter를 편집하며 ALLOW_ROOT=true를 설정하"
"세요."
