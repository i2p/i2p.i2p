#. hard to do {0} from here
#. setTunnelStatus("Accepting " + (100-(int)(100.0*probReject)) + "% of tunnels");
#: ../java/src/net/i2p/router/RouterThrottleImpl.java:244
#: ../java/src/net/i2p/router/RouterThrottleImpl.java:447
